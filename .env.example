AEGIS_ENVIRONMENT=development
AEGIS_PUBLIC_BASE_URL=http://localhost:8000
AEGIS_DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis
AEGIS_REDIS_URL=redis://redis:6379/0
AEGIS_DISCORD_CLIENT_ID=
AEGIS_DISCORD_CLIENT_SECRET=
AEGIS_DISCORD_REDIRECT_URI=http://localhost:8000/api/v1/auth/discord/callback
# Discord Developer Portal > your application > Bot > Token.
# Use the raw bot token only, not the client secret, public key, OAuth token, or "Bot <token>".
AEGIS_DISCORD_BOT_TOKEN=
AEGIS_TOKEN_HASH_KEY=change-this-long-random-value
AEGIS_STATE_SIGNING_KEY=change-this-long-random-value
AEGIS_CSRF_SIGNING_KEY=change-this-long-random-value
AEGIS_BOT_SIGNING_KEY_ID=dev-bot-key
AEGIS_BOT_SIGNING_PRIVATE_KEY=
AEGIS_BOT_SIGNING_PUBLIC_KEYS={}
AEGIS_ALLOWED_ORIGINS=["http://localhost:8000"]
AEGIS_TRUSTED_HOSTS=["localhost","127.0.0.1","api"]
AEGIS_DOCS_ENABLED=true
